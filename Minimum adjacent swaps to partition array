class Solution {
public:
    int minAdjacentSwaps(vector<int>& nums, int a, int b) {
        const long long MOD =1000000007LL;
        long long L =0, M=0, H=0;
        long long ans =0;

        for(int x : nums){
            if(x < a){
                ans += M + H;
                L++;
            }
            else if(x <= b){
                ans += H;
            M++;
        }
        else{
            H++;
        }
    }
        return ans%MOD;
        
    }
};©leetcode
